generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  MENTOR
  ADMIN
}

enum SessionStatus {
  PENDING
  ACCEPTED
  REJECTED
  COMPLETED
}

model User {
  id               Int       @id @default(autoincrement())
  name             String
  email            String    @unique
  password         String
  role             Role      @default(STUDENT)
  specializationId Int?
  rating           Float?
  disponibilitate  Boolean   @default(true)

  sessionsAsStudent Session[] @relation("StudentSessions")
  sessionsAsMentor  Session[] @relation("MentorSessions")
}

model Session {
  id         Int           @id @default(autoincrement())
  studentId  Int
  mentorId   Int
  date       DateTime
  status     SessionStatus @default(PENDING)
  topic      String?

  student    User          @relation("StudentSessions", fields: [studentId], references: [id])
  mentor     User          @relation("MentorSessions", fields: [mentorId], references: [id])
}