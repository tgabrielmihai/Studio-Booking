generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Am introdus rolul de ADMIN conform cerinței tale
enum Role {
  ARTIST
  ADMIN
}

model User {
  id        Int       @id @default(autoincrement())
  name      String
  email     String    @unique
  password  String
  role      Role      @default(ARTIST)
  bookings  Booking[] // Un utilizator poate avea mai multe rezervări
}

model Booking {
  id          Int      @id @default(autoincrement())
  date        DateTime
  studioRoom  String   // ex: "Vocal Booth", "Mixing Room A"
  equipment   String?  // ex: "Microfon Neumann U87, Compresor hardware"
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
}