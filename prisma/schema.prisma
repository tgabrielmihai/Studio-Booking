generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Am introdus rolul de ADMIN conform cerinței tale
enum Role {
  ARTIST
  ADMIN
}

model User {
  id        Int       @id @default(autoincrement())
  name      String
  email     String    @unique
  password  String?   
  googleId  String?   @unique
  role      Role      @default(ARTIST)
  bookings  Booking[]
  reviews   Review[]  // O nouă legătură: un utilizator poate avea mai multe review-uri
}

model Booking {
  id        Int      @id @default(autoincrement())
  date      String
  room      String
  status    String   @default("UPCOMING")
  price     Int
  createdAt DateTime @default(now())

  // Legătura înapoi către User
  userId    Int?     
  user      User?    @relation(fields: [userId], references: [id])
}

model Review {
  id        Int      @id @default(autoincrement())
  sessionId Int?
  room      String
  rating    Int
  text      String
  date      String
  createdAt DateTime @default(now())

  // Legătura structurală către User
  userId    Int?     
  user      User?    @relation(fields: [userId], references: [id])
}

model Gear {
  id          Int      @id @default(autoincrement())
  name        String
  type        String
  description String
  status      String   @default("Available")
  price       Int      
  imageUrl    String?  
}